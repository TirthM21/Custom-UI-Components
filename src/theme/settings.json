  "overrides": {
    "MuiBackdrop": {
      "root": {
        "backgroundColor": "rgba(34, 51, 84, 0.85)"
      }
    },
    "MuiFormHelperText": {
      "root": {
        "fontSize": "12px",
        "lineHeight": "16px",
        "letterSpacing": "0.4px",
        "color": "rgba(35, 49, 86, 0.4)"
      }
    },
    "MuiCssBaseline": {
      "@global": {
        "body": {
          "fontFamily": "Roboto, sans-serif",
          "fontWeight": 400,
          "lineHeight": 1.5,
          "color": "rgba(35, 49, 86, 0.9)"
        }
      }
    },
    "MuiSelect": {
      "root": {
        "borderRadius": "6px",
        "backgroundColor": "#F4F6F8",
        "color": "rgba(35, 49, 86, 0.9)",
        "&:focus": {
          "backgroundColor": "#ffffff"
        }
      },
      "select": {
        "paddingLeft": "12px",
        "paddingRight": "28px",
        "&:focus": {
          "backgroundColor": "#ffffff"
        }
      },
      "icon": {
        "top": "calc(50% - 12px)",
        "right": "12px",
        "color": "rgba(35, 49, 86, 0.9)"
      }
    },
    "MuiOutlinedInput": {
      "root": {
        "borderRadius": "6px",
        "&:hover $notchedOutline": {
          "borderColor": "#5569ff"
        },
        "&$focused $notchedOutline": {
          "borderColor": "#5569ff"
        }
      },
      "input": {
        "padding": "12px"
      }
    },
    "MuiPaginationItem": {
      "root": {
        "borderRadius": "6px",
        "&:hover": {
          "backgroundColor": "#5569ff",
          "color": "#ffffff"
        },
        "&$selected": {
          "backgroundColor": "#5569ff",
          "color": "#ffffff"
        }
      }
    },
    "MuiTab": {
      "root": {
        "textTransform": "initial",
        "fontWeight": 500,
        "fontSize": "14px",
        "lineHeight": "20px",
        "padding": "12px 24px",
        "borderRadius": "6px",
        "minWidth": "auto",
        "&$selected": {
          "backgroundColor": "#5569ff",
          "color": "#ffffff"
        }
      }
    }
  }
